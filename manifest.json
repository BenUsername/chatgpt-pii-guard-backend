{
  "manifest_version": 3,
  "name": "ChatGPT PII Guard",
  "version": "1.0",
  "description": "Scans ChatGPT conversations for PII and auto-deletes flagged chats.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js", "scanner-overlay.js"],
      "css": ["scanner-overlay.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["scanner-overlay.js", "scanner-overlay.css"],
      "matches": ["https://chatgpt.com/*"]
    }
  ]
}
